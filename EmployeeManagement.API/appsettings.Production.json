{
  "ConnectionStrings": {
    "DefaultConnection": "Server=${DB_SERVER};Database=EmployeeManagementDb;User Id=${DB_USER};Password=${DB_PASSWORD};TrustServerCertificate=True;Connection Timeout=30;Min Pool Size=5;Max Pool Size=100;",
    "Redis": "${REDIS_CONNECTION_STRING}"
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "ExpiryMinutes": 60,
    "Issuer": "EmployeeManagementAPI",
    "Audience": "EmployeeManagementClient"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://your-production-frontend.com"
    ],
    "AllowedMethods": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
    "AllowedHeaders": [ "Content-Type", "Authorization", "Idempotency-Key" ],
    "AllowCredentials": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "EmployeeManagement": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/employee-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "RateLimiting": {
    "FixedWindow": {
      "Window": "00:01:00",
      "PermitLimit": 100
    }
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 10485760,
      "KeepAliveTimeout": "00:02:00",
      "RequestHeadersTimeout": "00:00:10"
    }
  }
}


//Deployment Notes: Set these environment variables in your hosting platform:
//DB_SERVER=your-prod-server.database.windows.net
//DB_USER=employee_app
//DB_PASSWORD=${{ secrets.DB_PASSWORD }}  # Use secret manager
//JWT_SECRET_KEY=${{ secrets.JWT_KEY }}    # 256-bit random string
//REDIS_CONNECTION_STRING=your-redis:6379,password=${{ secrets.REDIS_PASSWORD }}