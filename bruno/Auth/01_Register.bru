meta {
  name: 01_Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "firstName": "Jane",
    "lastName": "Doe",
    "email": "jane54d32@example.com",
    "department": "HR",
    "password": "SecurePass123!",
    "role": "Admin"
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
