meta {
  name: GraphQL
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/graphql
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "query": "{ employees { edges { node { id firstName lastName email department } } } }"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
